{
  "name": "@rplryan/x402-proxy",
  "version": "1.0.0",
  "description": "Dead-simple reverse proxy that adds x402 payment requirements to any API",
  "type": "module",
  "bin": {
    "x402-proxy": "./src/cli.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": ["src", "README.md"],
  "keywords": ["x402", "proxy", "payments", "micropayments", "api", "web3"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rplryan/x402-proxy.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": { "node": ">=18" },
  "dependencies": {
    "@x402/core": "latest",
    "@x402/evm": "latest",
    "@x402/express": "latest",
    "commander": "^12.0.0",
    "express": "^4.19.0",
    "http-proxy-middleware": "^3.0.0"
  }
}
